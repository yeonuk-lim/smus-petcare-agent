# === 로컬 모드 (기본) — 인증 없이 localhost 에이전트에 연결 ===
AGENT_URL=http://localhost:8080

# === 클라우드 모드 (AgentCore Runtime + Cognito) ===
# 아래 변수들은 `agent/deploy-agentcore.sh` 실행 시 자동으로 이 파일에 기록됩니다.
# 수동으로 켜려면 위 AGENT_URL 줄을 지우고 아래 6줄의 주석을 해제하세요.
# AGENTCORE_RUNTIME_ARN=arn:aws:bedrock-agentcore:us-east-1:...:runtime/petcare_agent-xxxx
# AGENTCORE_REGION=us-east-1
# COGNITO_POOL_REGION=us-east-1
# COGNITO_CLIENT_ID=xxxxxxxx
# COGNITO_USERNAME=xxxxxxxx
# COGNITO_PASSWORD=xxxxxxxx
